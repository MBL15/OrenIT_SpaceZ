# Скопируйте в .env рядом с docker-compose.yml и задайте секрет.
JWT_SECRET=
# Порт веб-интерфейса на хосте (по умолчанию 8080)
PORT=8080
# Индекс pip при сборке api (по умолчанию в compose — TUNA). Официальный:
# PIP_INDEX_URL=https://pypi.org/simple
PIP_INDEX_URL=
# Реестр npm при сборке web (по умолчанию в compose — npmmirror). Официальный:
# NPM_REGISTRY=https://registry.npmjs.org
NPM_REGISTRY=
